# .env.example — canonical env for Chainbard.
# Source of truth: src/env/shared.ts. Copy to .env.local and fill REQUIRED below.
#
# Tags:  [required] no default — app won't build/run without it
#        [secret]   sensitive — mark "Sensitive" in Vercel; never expose
#        [test]     must be set for `bun test` (lives in .env.test)
#        [public]   NEXT_PUBLIC_* — shipped in browser bundle, never a secret
#        [opt-in]   default-OFF flag — enable only AFTER the Phase-0 x402 probe
#        commented  shows the built-in default; uncomment only to override

# ══ REQUIRED ══ [required][secret][test] — set in .env.local + Vercel (Prod+Preview)
ACE_API_KEY=                 # ACE platform auth (chat + image gen)
AGENT_SECRET_KEY_BASE58=     # base58 private signing key for agent wallet — full fund control
CRON_SECRET=                 # authorizes cron endpoint calls
DATABASE_URL=                # Postgres URL — MUST be a valid URL or build fails
DEMO_SECRET=                 # gates demo functionality

# ══ OPTIONAL SECRETS ══ [secret] — set in Vercel only if used; else fall back to public
# SOLANA_RPC_URL=            # read endpoint; unset -> public mainnet (rate-limited). Recommended for prod.
# SOLANA_SEND_RPC_URL=       # write/broadcast endpoint; unset -> SOLANA_RPC_URL -> public
# SYNAPSE_RPC_URL=           # read fallback after SOLANA_RPC_URL
# WEBHOOK_URL=               # notifications; unset -> disabled
# BLOB_READ_WRITE_TOKEN=     # Vercel Blob token; unset -> generated video/audio embeds the Ace URL directly (fail-soft mirror)
# QSTASH_TOKEN=              # Upstash QStash token; needed to create the durable hourly schedule
# QSTASH_CURRENT_SIGNING_KEY= # QStash signature verification (current key) for the workflow route
# QSTASH_NEXT_SIGNING_KEY=   # QStash signature verification (next key, during rotation)

# ══ CLIENT ══ [public] — inlined at build. Override the first two in prod.
# NEXT_PUBLIC_APP_URL=http://localhost:3000                        # set real prod URL — default breaks OG/canonical links
# NEXT_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com   # public default is rate-limited
# NEXT_PUBLIC_AGENT_WALLET=9cssRtj1tpo8juYMKVw4BLonEXnSH2e6bfc9Qp88fN48

# ══ DEFAULTS (skip unless overriding) ══ not required, not sensitive
# ACE platform & facilitator
# ACE_API_BASE=https://api.acedata.cloud
# ACE_CHAT_MODEL=
# [opt-in] SoTA "heavy" model for the write + Director steps. OFF by default: unset ->
# heavy steps fall back to ACE_CHAT_MODEL so the tick stays green out-of-the-box. Set
# to e.g. gpt-5.5-pro ONLY AFTER the Phase-0 x402 probe confirms it settles.
# ACE_CHAT_MODEL_HEAVY=
# ACE_FACILITATOR_PUBKEY=3SPm6qbgsDkj24MuR8Ss4sH97fziqyCiqFKDyeVU2igq
# ACE_FACILITATOR_URL=https://facilitator.acedata.cloud
# Autonomous x402 burn rail (ADR 0015)
# [opt-in] Master switch for the tick's USDC payment rail. OFF (default) keeps the
# bearer/credit path so a deploy never spends until the operator funds the agent wallet
# (USDC + SOL for self-broadcast fees) and opts in. ON settles every tick call in USDC.
# X402_CRON_ENABLED=
# MIN_TREASURY_USDC=0          # below this USDC balance the tick goes dormant (pre-flight). 0 disables the check.
# Video service (ADR 0015, abstract data-motion only)
# [opt-in] OFF by default; enable AFTER the probe. provider+model name the priciest-viable chain (veo3 -> kling fallback).
# VIDEO_ENABLED=
# VIDEO_PROVIDER=veo
# VIDEO_MODEL=veo3
# VIDEO_FALLBACK_PROVIDER=kling
# VIDEO_FALLBACK_MODEL=
# Audio service (ADR 0015, spoken-word narration only via Fish)
# [opt-in] OFF by default; enable AFTER the probe.
# AUDIO_ENABLED=
# AUDIO_PROVIDER=fish
# AUDIO_MODEL=
# MEDIA_COLLECT_TIMEOUT_MS=120000  # poll budget (ms) for inline collect of an async video/audio task; story still ships on timeout
# Multi-layer SERP (ADR 0015)
# WEB_EXTRACT_ENABLED=         # optional Web-Extract enrichment leg; OFF by default (reserved for a future leg)
# Upstash QStash / Workflow (durable hourly trigger, ADR 0015)
# WORKFLOW_URL=                # public URL of the durable workflow route the QStash schedule POSTs
# CRON_CADENCE_CRON=0 * * * *  # cron expression for the QStash schedule (default hourly)
# Pricing & on-chain constants
# ACE_COST_PER_RENDER_USDC=0.05
# DAILY_ACE_CAP_USDC=2
# [opt-in] Master switch for the in-memory daily cost cap. OFF (default): the real
# ceiling is the agent wallet's USDC balance, not a hardcoded budget. NOTE: shared
# singleton — disabling also lifts the cap on the reactive mint render (intended).
# COST_GUARD_ENABLED=
# MINT_PRICE_USDC=0.3
# USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
# Image generation
# IMAGE_GEN_TIMEOUT_MS=30000
# IMAGE_PROVIDER=nano-banana
# IMAGE_FALLBACK_PROVIDER=seedream
# PLACEHOLDER_IMAGE_URL=
# Sentinel & demo
# DAS_ASSET_ID=
# DEMO_SKIP_SENTINEL=
# SENTINEL_TOOL=spl-token_getBalance

# ══ SCRIPT-ONLY (never the deployed app; don't add to Vercel) ══
# BUYER_KEY_PATH=
# CHAT_ENDPOINT=
# CHAT_MODEL=
# MINT_ENDPOINT=
# SERP_ENDPOINT=
# TEST_AGENT_DESCRIPTION=
# TEST_AGENT_NAME=
