# Test-only env. Auto-loaded by `bun test` (NODE_ENV=test); .env.local is NOT
# loaded under test. Provides the five required-no-default secrets so `@/env`
# validation passes at module load (cost-guard → story-renderer/director import
# it). All other vars fall back to the defaults in src/env/shared.ts. Dummy
# values only — never real secrets.
ACE_API_KEY=test-ace-api-key
AGENT_SECRET_KEY_BASE58=test-agent-secret-key-base58
CRON_SECRET=test-cron-secret
DATABASE_URL=postgresql://test:test@localhost:5432/test
DEMO_SECRET=test-demo-secret
# Optional in prod, but the cron route returns 503 without it; pin a dummy so
# env.WEBHOOK_URL is set at load regardless of which test imports @/env first.
WEBHOOK_URL=https://discord.test/webhook
